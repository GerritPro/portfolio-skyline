<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler definition for the weekly patents scrape.

  Import via PowerShell (run once):

    Register-ScheduledTask `
      -Xml (Get-Content "C:\Users\gelle\portfolio-skyline\pipeline\scheduled_tasks\patents_weekly.xml" -Raw) `
      -TaskName "PortfolioSkyline-PatentsWeekly"

  Or via the Task Scheduler UI:
    Action → Import Task… → select this file.

  Schedule: Sunday 03:00 local time. USPTO grants drop Tuesdays, so
  Sunday gives a generous buffer and runs while you're asleep.

  The task runs `python -m pipeline.pull_patents` against your project
  venv. Adjust paths if your install location differs from the default
  C:\Users\gelle\portfolio-skyline.
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Author>Portfolio Skyline</Author>
    <Description>Weekly PatentsView bulk download + DuckDB ingest. Writes public/data/patents.json. One transaction covers all tickers.</Description>
    <URI>\PortfolioSkyline\PatentsWeekly</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-05-24T03:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Sunday />
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>true</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>true</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT2H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>C:\Users\gelle\portfolio-skyline\.venv\Scripts\python.exe</Command>
      <Arguments>-m pipeline.pull_patents</Arguments>
      <WorkingDirectory>C:\Users\gelle\portfolio-skyline</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
